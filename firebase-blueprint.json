{
  "entities": {
    "Concept": {
      "title": "Concept",
      "description": "A technical term or concept in the engineering lexicon.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the concept." },
        "term": { "type": "string", "description": "The name of the term." },
        "domain": { "type": "string", "description": "The engineering discipline or domain." },
        "definition_short": { "type": "string", "description": "A one-sentence summary." },
        "definition_detailed": { "type": "string", "description": "The full technical explanation." },
        "analogy": { "type": "string", "description": "A simple real-world comparison." },
        "examples": { "type": "array", "items": { "type": "string" }, "description": "Practical use cases." },
        "related_terms": { "type": "array", "items": { "type": "string" }, "description": "Terms related to this concept." },
        "prerequisites": { "type": "array", "items": { "type": "string" }, "description": "Terms that should be understood first." },
        "image_query": { "type": "string", "description": "Query for finding relevant images." },
        "syntax_or_example": { "type": "string", "description": "Code snippet or formal syntax." },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"], "description": "The complexity level." },
        "category": { "type": "string", "enum": ["Core", "Extended"], "description": "Whether it's a core concept or extended lexicon." },
        "breadcrumbs": { "type": "array", "items": { "type": "string" }, "description": "Navigation path." },
        "comparisons": { "type": "array", "items": { "type": "object", "properties": { "target": { "type": "string" }, "note": { "type": "string" } } }, "description": "Comparisons with other terms." },
        "common_misconceptions": { "type": "array", "items": { "type": "string" }, "description": "Common errors in understanding." }
      },
      "required": ["id", "term", "domain", "definition_short", "definition_detailed", "analogy", "difficulty", "category"]
    }
  },
  "firestore": {
    "/concepts/{conceptId}": {
      "schema": "Concept",
      "description": "The collection of all engineering concepts."
    }
  }
}
